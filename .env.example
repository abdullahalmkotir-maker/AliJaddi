# ——— AliJaddi Cloud (Supabase) — بيتا 0.2.1 ———
# مرجع المشروع: mfhtnfxdfpelrgzonxov
SUPABASE_URL=https://mfhtnfxdfpelrgzonxov.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# اختياري للهجرات/أدوات الإدارة:
# SUPABASE_SERVICE_ROLE_KEY=
# للتنفيذ التلقائي لـ scripts/apply_cloud_migrations.ps1 (نسخ URI من لوحة Supabase → Settings → Database):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# أو نفس القيمة تحت الاسم البديل:
# SUPABASE_DB_URL=postgresql://...
# SUPABASE_ACCESS_TOKEN=

# ——— مسارات المشاريع الشقيقة (لمزامنة التطوير المحلي) ———
# Windows مثال (مجلد سطح المكتب):
# ALIJADDI_CLOUD_ROOT=C:\Users\You\OneDrive\Desktop\AliJaddi Cloud
# ALIJADDI_ACCOUNT_ROOT=C:\Users\You\OneDrive\Desktop\AliJaddiAccount

# مزامنة رصيد النجوم مع السحابة (نفس سلوك AliJaddiAccount عند الربط)
CLOUD_SYNC_APPLY_STARS=true
